# =============================================================================
# WordPress Docker Environment
# =============================================================================
# Скопіюйте цей файл у .env і заповніть свої значення:
#   cp .env.example .env
# =============================================================================

# --- Project ---
PROJECT_NAME=impax_bud
WP_HOME=http://localhost:8000
WP_SITEURL=http://localhost:8000

# --- Languages ---
WP_LANG=uk
WP_EXTRA_LANGS=pl_PL

# --- Database ---
MYSQL_ROOT_PASSWORD=root_impax_2026!
MYSQL_DATABASE=impax_bd
MYSQL_USER=impax_user
MYSQL_PASSWORD=impax_dev_2026!

# --- WordPress ---
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=impax_bd
WORDPRESS_DB_USER=impax_user
WORDPRESS_DB_PASSWORD=impax_dev_2026!
WORDPRESS_TABLE_PREFIX=wpib_
WORDPRESS_DEBUG=1
WORDPRESS_CONFIG_EXTRA=

# --- WordPress Admin ---
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com

# --- Ports ---
WP_PORT=8000
DB_PORT=3307
PMA_PORT=8081
NODE_PORT=3000

# --- Xdebug ---
XDEBUG_MODE=develop,debug
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003
XDEBUG_IDEKEY=VSCODE
